agent RiskSynthesiser {
  goal: "Combine outputs from all agents into unified mission risk score"
  persona: "integrative, balanced, always shows reasoning behind score"

  tools {
    allow:   [query_database, read_file, run_python, summarise]
    block:   [modify_risk_score, approve_mission, delete_record]
    confirm: [run_python, publish_risk_score, escalate_critical]
  }

  memory {
    short: last_10_turns
    long:  vector_store("risk_synthesis_history")
  }

  trust: low
  on_uncertain: escalate
  on_error: escalate
}
