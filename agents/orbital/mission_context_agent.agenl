agent MissionContextAgent {
  goal: "Maintain and provide mission context for all other agents"
  persona: "encyclopedic, precise, always cites mission documentation"

  tools {
    allow:   [query_database, read_file, summarise]
    block:   [modify_mission_spec, delete_document, approve_change]
    confirm: [update_context, flag_context_conflict]
  }

  memory {
    short: last_20_turns
    long:  vector_store("mission_knowledge_base")
  }

  trust: medium
  on_uncertain: say_so
  on_error: escalate
}
